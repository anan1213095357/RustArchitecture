<!DOCTYPE html>
<html lang="zh">
	<head>
		<meta charset="UTF-8">
		<title>Babylon.js Rust-style Building System & Zombie Survival</title>
		<script src="https://cdn.babylonjs.com/babylon.js"></script>
		<script src="https://cdn.babylonjs.com/cannon.js"></script>
		<script src="https://cdn.babylonjs.com/loaders/babylonjs.loaders.min.js"></script>
		<style>
			body,
			html {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow: hidden;
				background-color: #000;
			}

			#renderCanvas {
				width: 100%;
				height: 100%;
				touch-action: none;
			}

			#ui {
				position: absolute;
				bottom: 20px;
				left: 20px;
				color: white;
				font-family: sans-serif;
				background: rgba(0, 0, 0, 0.85);
				padding: 15px;
				border-radius: 8px;
				user-select: none;
				max-width: 350px;
				z-index: 5;
			}

			#crosshair {
				position: absolute;
				top: 50%;
				left: 50%;
				width: 6px;
				height: 6px;
				background: rgba(255, 255, 255, 0.9);
				border-radius: 50%;
				transform: translate(-50%, -50%);
				pointer-events: none;
				z-index: 10;
				box-shadow: 0 0 4px rgba(0, 0, 0, 0.5);
			}

			.key {
				color: #f1c40f;
				font-weight: bold;
				background: #333;
				border-radius: 3px;
				padding: 2px 6px;
				margin: 0 2px;
			}

			p {
				margin: 6px 0;
				font-size: 14px;
			}

			h3 {
				margin-top: 0;
				color: #2ecc71;
				border-bottom: 1px solid #555;
				padding-bottom: 5px;
			}

			#controls {
				font-size: 13px;
				color: #ccc;
			}

			/* 玩家状态UI (血条和倒计时) */
			#playerStats {
				position: absolute;
				bottom: 20px;
				right: 20px;
				color: white;
				font-family: sans-serif;
				background: rgba(0, 0, 0, 0.85);
				padding: 15px;
				border-radius: 8px;
				user-select: none;
				width: 250px;
				z-index: 5;
			}

			#hpContainer {
				width: 100%;
				height: 20px;
				background: #333;
				border-radius: 10px;
				overflow: hidden;
				margin-bottom: 10px;
				border: 2px solid #222;
			}

			#hpBar {
				width: 100%;
				height: 100%;
				background: #e74c3c;
				transition: width 0.2s ease-out;
			}

			#prepTimer {
				font-size: 18px;
				font-weight: bold;
				color: #f1c40f;
				text-align: center;
			}

			#damageOverlay {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: rgba(255, 0, 0, 0.3);
				pointer-events: none;
				opacity: 0;
				transition: opacity 0.1s;
				z-index: 4;
			}

			/* 滑动轮盘样式 */
			#radial-menu-overlay {
				display: none;
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: rgba(0, 0, 0, 0.4);
				backdrop-filter: blur(5px);
				z-index: 999;
				user-select: none;
				pointer-events: none;
			}

			#radial-center {
				position: absolute;
				top: 50%;
				left: 50%;
				width: 680px;
				height: 680px;
				transform: translate(-50%, -50%);
				border-radius: 50%;
				background: rgba(30, 30, 30, 0.6);
				box-shadow: 0 0 40px rgba(0, 0, 0, 0.8);
				border: 2px solid #555;
			}

			.radial-item {
				position: absolute;
				top: 50%;
				left: 50%;
				width: 86px;
				height: 90px;
				margin-left: -43px;
				margin-top: -45px;
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.1);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				transition: all 0.15s ease-out;
				color: white;
				font-family: sans-serif;
				font-size: 13px;
				opacity: 0.7;
			}

			.radial-item.active {
				background: rgba(46, 204, 113, 0.5);
				border: 2px solid #2ecc71;
				transform: scale(1.15);
				opacity: 1;
				z-index: 10;
			}

			.radial-item.active-destroy {
				background: rgba(231, 76, 60, 0.6);
				border: 2px solid #e74c3c;
				transform: scale(1.15);
				opacity: 1;
				z-index: 10;
			}

			.radial-item svg {
				width: 40px;
				height: 40px;
				margin-bottom: 6px;
				filter: drop-shadow(0px 2px 2px rgba(0, 0, 0, 0.5));
			}

			#radial-cursor {
				position: absolute;
				top: 50%;
				left: 50%;
				width: 18px;
				height: 18px;
				background: white;
				border-radius: 50%;
				transform: translate(-50%, -50%);
				box-shadow: 0 0 12px rgba(255, 255, 255, 0.8);
				transition: transform 0.05s linear;
				z-index: 1000;
			}

			#radial-center-inner {
				position: absolute;
				top: 50%;
				left: 50%;
				width: 90px;
				height: 90px;
				transform: translate(-50%, -50%);
				border-radius: 50%;
				background: rgba(20, 20, 20, 0.9);
				border: 2px solid #555;
				display: flex;
				align-items: center;
				justify-content: center;
				color: #aaa;
				font-size: 13px;
				text-align: center;
			}
		</style>
	</head>
	<body>
		<canvas id="renderCanvas"></canvas>
		<div id="crosshair"></div>
		<div id="damageOverlay"></div>

		<div id="ui">
			<h3>生存建筑 & 射击系统</h3>
			<p>建造模式: <span id="buildModeStatus" style="color: #e74c3c; font-weight:bold;">关闭 (射击模式)</span></p>
			<p>当前工具: <span id="modeText" style="color: #2ecc71; font-weight:bold; font-size:16px;">方形地基</span></p>
			<hr style="border-color:#555">
			<div id="controls">
				<p><span class="key">W A S D</span> 移动 | <span class="key">空格</span> 跳跃</p>
				<p><span class="key">B</span> 键: 开关建造 | <span class="key">R</span> 键: 旋转朝向</p>
				<p><span class="key">长按右键</span>: 滑动轮盘 | <span class="key">左键</span>: 放置/开火</p>
			</div>
		</div>

		<div id="playerStats">
			<div id="hpContainer">
				<div id="hpBar"></div>
			</div>
			<div id="prepTimer">准备时间: 60s</div>
		</div>

		<div id="radial-menu-overlay">
			<div id="radial-center">
				<div id="radial-center-inner">滑动选择<br>松开确认</div>
			</div>
			<div id="radial-cursor"></div>
		</div>

		<script>
			const canvas = document.getElementById("renderCanvas");
			const engine = new BABYLON.Engine(canvas, true);

			const GRID_SIZE = 4;
			const WALL_HEIGHT = 3;
			const BASE_THICKNESS = 0.1;

			const ZOMBIE_MODEL_URL = "https://models.babylonjs.com/";
			const ZOMBIE_MODEL_FILE = "HVGirl.glb";

			// ✅ 修正1：缩放扩大了1.5倍
			const ZOMBIE_SCALE = 0.098;

			const TYPE = {
				FOUNDATION: 1,
				WALL: 2,
				FLOOR: 3,
				FOUNDATION_TRI: 4,
				LOW_WALL: 5,
				DOORWAY: 6,
				WINDOW: 7,
				STAIRS: 8,
				FLOOR_TRI: 9,
				STAIRS_L: 10,
				STAIRS_U: 11,
				STAIRS_SPIRAL: 12,
				DESTROY: 99
			};
			const wheelItems = [{
				type: TYPE.FOUNDATION,
				name: "方形地基"
			}, {
				type: TYPE.WALL,
				name: "标准墙壁"
			}, {
				type: TYPE.FLOOR,
				name: "方形天花板"
			}, {
				type: TYPE.FOUNDATION_TRI,
				name: "三角地基"
			}, {
				type: TYPE.LOW_WALL,
				name: "半高矮墙"
			}, {
				type: TYPE.DOORWAY,
				name: "门框"
			}, {
				type: TYPE.WINDOW,
				name: "窗户墙面"
			}, {
				type: TYPE.STAIRS,
				name: "直行楼梯"
			}, {
				type: TYPE.FLOOR_TRI,
				name: "三角天花板"
			}, {
				type: TYPE.STAIRS_L,
				name: "L型楼梯"
			}, {
				type: TYPE.STAIRS_U,
				name: "U型楼梯"
			}, {
				type: TYPE.STAIRS_SPIRAL,
				name: "螺旋楼梯"
			}, {
				type: TYPE.DESTROY,
				name: "拆除工具"
			}];

			const isFoundationType = (t) => t === TYPE.FOUNDATION || t === TYPE.FOUNDATION_TRI;
			const isWallType = (t) => t === TYPE.WALL || t === TYPE.LOW_WALL || t === TYPE.DOORWAY || t === TYPE.WINDOW;
			const isFloorType = (t) => t === TYPE.FLOOR || t === TYPE.FLOOR_TRI;
			const isStairType = (t) => t === TYPE.STAIRS || t === TYPE.STAIRS_L || t === TYPE.STAIRS_U || t === TYPE
				.STAIRS_SPIRAL;

			let isBuildMode = false;
			let isWheelOpen = false;
			let currentMode = TYPE.FOUNDATION;
			let manualRotationSteps = 0;
			let lastOutlinedMesh = null;
			let radialDelta = {
				x: 0,
				y: 0
			};
			let activeWheelIndex = -1;
			let wheelDOMItems = [];
			const blocks = new Map();
			const templates = {};
			const ghostMeshes = {};
			const globalDoors = [];
			const Sockets = {};

			// ✅ 新增：防递归承重检测锁
			let isCheckingIntegrity = false;

			Sockets[TYPE.FOUNDATION] = Sockets[TYPE.FLOOR] = [{
				pos: new BABYLON.Vector3(0, 0, GRID_SIZE / 2),
				norm: new BABYLON.Vector3(0, 0, 1)
			}, {
				pos: new BABYLON.Vector3(0, 0, -GRID_SIZE / 2),
				norm: new BABYLON.Vector3(0, 0, -1)
			}, {
				pos: new BABYLON.Vector3(GRID_SIZE / 2, 0, 0),
				norm: new BABYLON.Vector3(1, 0, 0)
			}, {
				pos: new BABYLON.Vector3(-GRID_SIZE / 2, 0, 0),
				norm: new BABYLON.Vector3(-1, 0, 0)
			}];
			let triSockets = [];
			let baseNorm = new BABYLON.Vector3(0, 0, -1);
			let basePos = new BABYLON.Vector3(0, 0, -GRID_SIZE / (2 * Math.sqrt(3)));
			for (let i = 0; i < 3; i++) {
				let mat = BABYLON.Matrix.RotationY(i * 2 * Math.PI / 3);
				triSockets.push({
					pos: BABYLON.Vector3.TransformCoordinates(basePos, mat),
					norm: BABYLON.Vector3.TransformNormal(baseNorm, mat)
				});
			}
			Sockets[TYPE.FOUNDATION_TRI] = Sockets[TYPE.FLOOR_TRI] = triSockets;
			Sockets[TYPE.WALL] = Sockets[TYPE.DOORWAY] = Sockets[TYPE.WINDOW] = [{
				pos: new BABYLON.Vector3(0, WALL_HEIGHT / 2, 0),
				detectPos: new BABYLON.Vector3(0, WALL_HEIGHT / 2, 1.0),
				norm: new BABYLON.Vector3(0, 0, 1)
			}, {
				pos: new BABYLON.Vector3(0, WALL_HEIGHT / 2, 0),
				detectPos: new BABYLON.Vector3(0, WALL_HEIGHT / 2, -1.0),
				norm: new BABYLON.Vector3(0, 0, -1)
			}];
			Sockets[TYPE.LOW_WALL] = [{
				pos: new BABYLON.Vector3(0, WALL_HEIGHT / 4, 0),
				detectPos: new BABYLON.Vector3(0, WALL_HEIGHT / 4, 1.0),
				norm: new BABYLON.Vector3(0, 0, 1)
			}, {
				pos: new BABYLON.Vector3(0, WALL_HEIGHT / 4, 0),
				detectPos: new BABYLON.Vector3(0, WALL_HEIGHT / 4, -1.0),
				norm: new BABYLON.Vector3(0, 0, -1)
			}];

			function getUniqueId() {
				return Math.random().toString(36).substr(2, 9);
			}

			function getIconSVG(type) {
				let content = '';
				switch (type) {
					case 1:
						content = `<rect x="20" y="30" width="60" height="40" fill="#7f8c8d" />`;
						break;
					case 2:
						content = `<rect x="30" y="10" width="40" height="80" fill="#95a5a6" />`;
						break;
					case 3:
						content = `<rect x="15" y="45" width="70" height="10" fill="#bdc3c7" />`;
						break;
					case 4:
						content = `<polygon points="50,20 20,80 80,80" fill="#7f8c8d" />`;
						break;
					case 5:
						content = `<rect x="30" y="50" width="40" height="40" fill="#95a5a6" />`;
						break;
					case 6:
						content =
							`<rect x="25" y="10" width="50" height="80" fill="#95a5a6" /><rect x="35" y="40" width="30" height="50" fill="#2c3e50" />`;
						break;
					case 7:
						content =
							`<rect x="25" y="10" width="50" height="80" fill="#95a5a6" /><rect x="35" y="30" width="30" height="30" fill="#2c3e50" />`;
						break;
					case 8:
						content = `<polygon points="20,80 80,80 80,20 60,20 60,40 40,40 40,60 20,60" fill="#e67e22" />`;
						break;
					case 9:
						content = `<polygon points="50,30 20,70 80,70" fill="#bdc3c7" />`;
						break;
					case 10:
						content = `<path d="M20,80 L80,80 L80,40 L60,40 L60,60 L20,60 Z" fill="#e67e22" />`;
						break;
					case 11:
						content = `<path d="M20,80 L80,80 L80,20 L60,20 L60,60 L40,60 L40,20 L20,20 Z" fill="#e67e22" />`;
						break;
					case 12:
						content = `<circle cx="50" cy="50" r="30" stroke="#e67e22" stroke-width="12" fill="none" />`;
						break;
					case 99:
						content =
							`<path d="M25,25 L75,75 M75,25 L25,75" stroke="#e74c3c" stroke-width="15" stroke-linecap="round"/>`;
						break;
				}
				return `<svg viewBox="0 0 100 100">${content}</svg>`;
			}

			const radialCenter = document.getElementById("radial-center");

			function initRadialMenu() {
				const radius = 280,
					total = wheelItems.length;
				for (let i = 0; i < total; i++) {
					const angle = (i * (360 / total) - 90) * (Math.PI / 180),
						x = Math.cos(angle) * radius,
						y = Math.sin(angle) * radius;
					const item = document.createElement("div");
					item.className = "radial-item";
					item.style.left = `calc(50% + ${x}px)`;
					item.style.top = `calc(50% + ${y}px)`;
					item.innerHTML = `${getIconSVG(wheelItems[i].type)}<span>${wheelItems[i].name}</span>`;
					radialCenter.appendChild(item);
					wheelDOMItems.push(item);
				}
			}
			initRadialMenu();

			function updateRadialUI() {
				wheelDOMItems.forEach((el, index) => {
					el.classList.remove('active', 'active-destroy');
					if (index === activeWheelIndex) {
						if (wheelItems[index].type === TYPE.DESTROY) el.classList.add('active-destroy');
						else el.classList.add('active');
					}
				});
			}

			function clearOutline() {
				if (lastOutlinedMesh) {
					lastOutlinedMesh.renderOutline = false;
					lastOutlinedMesh = null;
				}
			}

			const createScene = function() {
				const scene = new BABYLON.Scene(engine);
				scene.enablePhysics(new BABYLON.Vector3(0, -9.81, 0), new BABYLON.CannonJSPlugin());
				scene.collisionsEnabled = true;

				const camera = new BABYLON.UniversalCamera("camera", new BABYLON.Vector3(0, 4, -10), scene);
				camera.setTarget(BABYLON.Vector3.Zero());
				camera.attachControl(canvas, true);
				camera.speed = 2;
				camera.inertia = 0.1;
				camera.angularSensibility = 800;
				camera.keysUp.push(87);
				camera.keysDown.push(83);
				camera.keysLeft.push(65);
				camera.keysRight.push(68);
				camera.checkCollisions = true;
				camera.ellipsoid = new BABYLON.Vector3(0.4, 0.8, 0.4);
				camera.minZ = 0.05;
				const originalCheckInputs = camera._checkInputs.bind(camera);
				camera._checkInputs = function() {
					let savedPitch = this.rotation.x;
					this.rotation.x = 0;
					originalCheckInputs();
					let mousePitchDelta = this.rotation.x;
					this.rotation.x = savedPitch + mousePitchDelta;
					this.cameraDirection.y = velocityY;
				};

				const gunParent = new BABYLON.TransformNode("gunParent", scene);
				gunParent.parent = camera;
				const gunBody = BABYLON.MeshBuilder.CreateBox("gunBody", {
					width: 0.1,
					height: 0.15,
					depth: 0.4
				}, scene);
				gunBody.position = new BABYLON.Vector3(0.3, -0.3, 0.6);
				gunBody.parent = gunParent;
				const gunMat = new BABYLON.StandardMaterial("gunMat", scene);
				gunMat.diffuseColor = new BABYLON.Color3(0.2, 0.2, 0.2);
				gunBody.material = gunMat;
				const gunBarrel = BABYLON.MeshBuilder.CreateCylinder("gunBarrel", {
					diameter: 0.04,
					height: 0.5
				}, scene);
				gunBarrel.rotation.x = Math.PI / 2;
				gunBarrel.position = new BABYLON.Vector3(0.3, -0.27, 0.9);
				gunBarrel.parent = gunParent;
				gunBarrel.material = gunMat;

				let gunRecoilOffset = 0;
				scene.onBeforeRenderObservable.add(() => {
					gunRecoilOffset = BABYLON.Scalar.Lerp(gunRecoilOffset, 0, 0.2);
					gunParent.position.z = -gunRecoilOffset;
					gunParent.rotation.x = -gunRecoilOffset * 0.5;
				});

				const playerBody = new BABYLON.TransformNode("playerBody", scene);
				BABYLON.SceneLoader.ImportMeshAsync("", "https://models.babylonjs.com/", "dummy3.babylon", scene).then((
					result) => {
					const char = result.meshes[0];
					char.parent = playerBody;
					char.position.y = -1.0;
					char.rotation.y = Math.PI;
					result.meshes.forEach(m => {
						m.isPickable = false;
						m.checkCollisions = false;
					});
					if (result.animationGroups && result.animationGroups.length > 0) result.animationGroups[0].play(
						true);
				});

				let velocityY = 0,
					isGrounded = false;
				window.addEventListener("keydown", (e) => {
					if (e.code === "Space" && isGrounded && engine.isPointerLock) {
						velocityY = 0.2;
						isGrounded = false;
					}
					if (e.key.toLowerCase() === 'b') {
						isBuildMode = !isBuildMode;
						const st = document.getElementById("buildModeStatus");
						st.innerText = isBuildMode ? "已开启 (建造模式)" : "关闭 (射击模式)";
						st.style.color = isBuildMode ? "#2ecc71" : "#e74c3c";
						gunParent.setEnabled(!isBuildMode);
						if (!isBuildMode) {
							Object.values(ghostMeshes).forEach(g => g.isVisible = false);
							clearOutline();
						}
					}
					if (e.key.toLowerCase() === 'r' && isBuildMode && currentMode !== TYPE.DESTROY)
						manualRotationSteps++;
				});
				scene.onBeforeRenderObservable.add(() => {
					playerBody.position = camera.position.clone();
					playerBody.position.y -= 0.8;
					let camFwd = camera.getDirection(BABYLON.Vector3.Forward());
					playerBody.rotation.y = Math.atan2(camFwd.x, camFwd.z);

					if (velocityY > 0) {
						let headPick = scene.pickWithRay(new BABYLON.Ray(camera.position, new BABYLON.Vector3(0, 1,
							0), 0.9), (m) => m && m.checkCollisions);
						if (headPick && headPick.hit) {
							velocityY = 0;
						}
					}

					let rayOrigin = camera.position.clone();
					rayOrigin.y -= 0.5;
					let pick = scene.pickWithRay(new BABYLON.Ray(rayOrigin, new BABYLON.Vector3(0, -1, 0), 2.5), (
						m) => m && m.checkCollisions);
					let isValidGround = false;
					if (pick && pick.hit && pick.pickedPoint) {
						let normal = pick.getNormal(true);
						if (normal && normal.y > 0.5) isValidGround = true;
					}

					if (isValidGround) {
						let gy = pick.pickedPoint.y,
							ty = gy + 1.8,
							dist = camera.position.y - gy;
						if (dist <= (isGrounded ? 2.05 : 1.95) && velocityY <= 0) {
							isGrounded = true;
							velocityY = 0;
							camera.position.y = Math.abs(ty - camera.position.y) > 0.01 ? BABYLON.Scalar.Lerp(camera
								.position.y, ty, 0.4) : ty;
						} else {
							isGrounded = false;
							velocityY = Math.max(-0.4, velocityY - 0.012);
						}
					} else {
						isGrounded = false;
						velocityY = Math.max(-0.4, velocityY - 0.012);
					}
				});

				const light = new BABYLON.HemisphericLight("light", new BABYLON.Vector3(0, 1, 0), scene);
				light.intensity = 0.8;
				const dirLight = new BABYLON.DirectionalLight("dirLight", new BABYLON.Vector3(-1, -2, -1), scene);
				dirLight.intensity = 0.5;
				const groundMat = new BABYLON.StandardMaterial("gmat", scene);
				groundMat.diffuseTexture = new BABYLON.Texture("https://playground.babylonjs.com/textures/grass.jpg", scene);
				groundMat.diffuseTexture.uScale = 15;
				groundMat.diffuseTexture.vScale = 15;
				const matWood = new BABYLON.StandardMaterial("wood", scene);
				matWood.diffuseTexture = new BABYLON.Texture("https://playground.babylonjs.com/textures/wood.jpg", scene);
				const matGhostValid = new BABYLON.StandardMaterial("ghostV", scene);
				matGhostValid.diffuseColor = new BABYLON.Color3(0.2, 1, 0.2);
				matGhostValid.alpha = 0.5;

				const ground = BABYLON.MeshBuilder.CreateGround("ground", {
					width: 200,
					height: 200
				}, scene);
				ground.physicsImpostor = new BABYLON.PhysicsImpostor(ground, BABYLON.PhysicsImpostor.BoxImpostor, {
					mass: 0,
					restitution: 0
				}, scene);
				ground.material = groundMat;
				ground.checkCollisions = true;

				function createStairwayPart(name, w, h, d, c) {
					let parts = [],
						sH = h / c,
						sD = d / c;
					for (let i = 0; i < c; i++) {
						let s = BABYLON.MeshBuilder.CreateBox(name + i, {
							width: w,
							height: sH,
							depth: sD
						}, scene);
						s.position.y = (i + 0.5) * sH - h / 2;
						s.position.z = (i + 0.5) * sD - d / 2;
						parts.push(s);
					}
					return BABYLON.Mesh.MergeMeshes(parts, true, true, undefined, false, true);
				}

				function initTemplates() {
					templates[TYPE.FOUNDATION] = BABYLON.MeshBuilder.CreateBox("t_f", {
						width: GRID_SIZE,
						height: BASE_THICKNESS,
						depth: GRID_SIZE
					}, scene);
					templates[TYPE.FLOOR] = BABYLON.MeshBuilder.CreateBox("t_fl", {
						width: GRID_SIZE,
						height: BASE_THICKNESS,
						depth: GRID_SIZE
					}, scene);
					templates[TYPE.WALL] = BABYLON.MeshBuilder.CreateBox("t_w", {
						width: GRID_SIZE,
						height: WALL_HEIGHT,
						depth: BASE_THICKNESS
					}, scene);
					templates[TYPE.LOW_WALL] = BABYLON.MeshBuilder.CreateBox("t_lw", {
						width: GRID_SIZE,
						height: WALL_HEIGHT / 2,
						depth: BASE_THICKNESS
					}, scene);
					let r = GRID_SIZE / Math.sqrt(3);
					templates[TYPE.FOUNDATION_TRI] = BABYLON.MeshBuilder.CreateCylinder("t_ftri", {
						diameter: r * 2,
						height: BASE_THICKNESS,
						tessellation: 3
					}, scene);
					templates[TYPE.FOUNDATION_TRI].rotation.y = -Math.PI / 2;
					templates[TYPE.FOUNDATION_TRI].bakeCurrentTransformIntoVertices();
					templates[TYPE.FLOOR_TRI] = templates[TYPE.FOUNDATION_TRI].clone("t_fltri");

					let wBox = BABYLON.MeshBuilder.CreateBox("wb", {
						width: GRID_SIZE,
						height: WALL_HEIGHT,
						depth: BASE_THICKNESS
					}, scene);
					let dHole = BABYLON.MeshBuilder.CreateBox("dh", {
						width: 1.2,
						height: 2.2,
						depth: BASE_THICKNESS * 2
					}, scene);
					dHole.position.y = -0.4;
					let doorFrame = BABYLON.CSG.FromMesh(wBox).subtract(BABYLON.CSG.FromMesh(dHole)).toMesh("t_door_frame",
						matWood, scene);
					wBox.dispose();
					dHole.dispose();
					let hinge = new BABYLON.TransformNode("t_hinge", scene);
					hinge.parent = doorFrame;
					hinge.position = new BABYLON.Vector3(-0.6, -0.425, 0);
					let doorPanel = BABYLON.MeshBuilder.CreateBox("dp", {
						width: 1.2,
						height: 2.15,
						depth: 0.05
					}, scene);
					doorPanel.parent = hinge;
					doorPanel.position = new BABYLON.Vector3(0.6, 0, 0);
					doorPanel.material = matWood;
					doorPanel.checkCollisions = true;

					templates[TYPE.DOORWAY] = doorFrame;

					let wBox2 = BABYLON.MeshBuilder.CreateBox("wb2", {
						width: GRID_SIZE,
						height: WALL_HEIGHT,
						depth: BASE_THICKNESS
					}, scene);
					let wHole = BABYLON.MeshBuilder.CreateBox("wh", {
						width: 1.5,
						height: 1.2,
						depth: BASE_THICKNESS * 2
					}, scene);
					wHole.position.y = 0.2;
					templates[TYPE.WINDOW] = BABYLON.CSG.FromMesh(wBox2).subtract(BABYLON.CSG.FromMesh(wHole)).toMesh(
						"t_win", matWood, scene);
					wBox2.dispose();
					wHole.dispose();

					let stairVis = createStairwayPart("t_stair_v", GRID_SIZE, WALL_HEIGHT, GRID_SIZE, 12);
					stairVis.position.y = WALL_HEIGHT / 2;
					stairVis.bakeCurrentTransformIntoVertices();
					templates[TYPE.STAIRS] = stairVis;
					let visPartsL = [];
					let landL = BABYLON.MeshBuilder.CreateBox("lL", {
						width: GRID_SIZE / 2,
						height: BASE_THICKNESS,
						depth: GRID_SIZE / 2
					}, scene);
					landL.position = new BABYLON.Vector3(GRID_SIZE / 4, WALL_HEIGHT / 2 - BASE_THICKNESS / 2, GRID_SIZE / 4);
					visPartsL.push(landL);
					let lowVisL = createStairwayPart("lowVL", GRID_SIZE / 2, WALL_HEIGHT / 2, GRID_SIZE / 2, 6);
					lowVisL.position = new BABYLON.Vector3(GRID_SIZE / 4, WALL_HEIGHT / 4, -GRID_SIZE / 4);
					visPartsL.push(lowVisL);
					let upVisL = createStairwayPart("upVL", GRID_SIZE / 2, WALL_HEIGHT / 2, GRID_SIZE / 2, 6);
					upVisL.rotation.y = -Math.PI / 2;
					upVisL.position = new BABYLON.Vector3(-GRID_SIZE / 4, WALL_HEIGHT * 0.75, GRID_SIZE / 4);
					upVisL.bakeCurrentTransformIntoVertices();
					visPartsL.push(upVisL);
					templates[TYPE.STAIRS_L] = BABYLON.Mesh.MergeMeshes(visPartsL, true, true, undefined, false, true);
					let visPartsU = [];
					let landU = BABYLON.MeshBuilder.CreateBox("lU", {
						width: GRID_SIZE,
						height: BASE_THICKNESS,
						depth: GRID_SIZE / 2
					}, scene);
					landU.position = new BABYLON.Vector3(0, WALL_HEIGHT / 2 - BASE_THICKNESS / 2, GRID_SIZE / 4);
					visPartsU.push(landU);
					let lowVisU = createStairwayPart("lowVU", GRID_SIZE / 2, WALL_HEIGHT / 2, GRID_SIZE / 2, 6);
					lowVisU.position = new BABYLON.Vector3(-GRID_SIZE / 4, WALL_HEIGHT / 4, -GRID_SIZE / 4);
					visPartsU.push(lowVisU);
					let upVisU = createStairwayPart("upVU", GRID_SIZE / 2, WALL_HEIGHT / 2, GRID_SIZE / 2, 6);
					upVisU.rotation.y = Math.PI;
					upVisU.position = new BABYLON.Vector3(GRID_SIZE / 4, WALL_HEIGHT * 0.75, -GRID_SIZE / 4);
					upVisU.bakeCurrentTransformIntoVertices();
					visPartsU.push(upVisU);
					templates[TYPE.STAIRS_U] = BABYLON.Mesh.MergeMeshes(visPartsU, true, true, undefined, false, true);
					let visPartsS = [];
					let pole = BABYLON.MeshBuilder.CreateCylinder("pole", {
						diameter: 0.8,
						height: WALL_HEIGHT
					}, scene);
					pole.position.y = WALL_HEIGHT / 2;
					visPartsS.push(pole);
					for (let i = 0; i < 16; i++) {
						let step = BABYLON.MeshBuilder.CreateCylinder("sV" + i, {
							diameter: GRID_SIZE,
							height: WALL_HEIGHT / 16,
							arc: 1 / 16,
							enclose: true
						}, scene);
						step.position.y = (i + 0.5) * (WALL_HEIGHT / 16);
						step.rotation.y = i * (Math.PI * 2 / 16);
						step.bakeCurrentTransformIntoVertices();
						visPartsS.push(step);
					}
					templates[TYPE.STAIRS_SPIRAL] = BABYLON.Mesh.MergeMeshes(visPartsS, true, true, undefined, false, true);

					for (let key in templates) {
						let t = templates[key];
						t.material = matWood;
						t.isVisible = false;
						t.isPickable = false;
						let ghost = t.clone("ghost_" + key);
						ghost.material = matGhostValid;
						ghost.isVisible = false;
						ghost.isPickable = false;
						ghost.checkCollisions = false;
						ghost.getChildMeshes(false).forEach(c => {
							c.material = matGhostValid;
							if (key == TYPE.DOORWAY) c.isVisible = false;
						});
						ghostMeshes[key] = ghost;
					}
				}
				initTemplates();

				let currentPlacementValid = false;
				let currentPlacementData = null;

				function shootWeapon() {
					gunRecoilOffset = 0.15;
					let ray = new BABYLON.Ray(camera.position, camera.getDirection(BABYLON.Vector3.Forward()), 100);
					let hit = scene.pickWithRay(ray, (m) => m.isPickable && m.isVisible);

					let endPoint = hit.hit ? hit.pickedPoint : ray.origin.add(ray.direction.scale(100));
					let visualOrigin = camera.position.clone().add(camera.getDirection(BABYLON.Vector3.Right()).scale(0.3))
						.add(camera.getDirection(BABYLON.Vector3.Down()).scale(0.3));
					let line = BABYLON.MeshBuilder.CreateLines("tracer", {
						points: [visualOrigin, endPoint]
					}, scene);
					line.color = new BABYLON.Color3(1, 0.8, 0);
					setTimeout(() => line.dispose(), 80);

					if (hit.hit && hit.pickedMesh) {
						let md = hit.pickedMesh.metadata;
						if (md && md.isZombie) {
							let rootNode = md.root;
							let zObj = zombiesList.find(z => z.root === rootNode);
							if (zObj && !zObj.isDead) {
								zObj.hp -= 40;

								hit.pickedMesh.renderOutline = true;
								hit.pickedMesh.outlineColor = BABYLON.Color3.Red();
								hit.pickedMesh.outlineWidth = 0.05;
								setTimeout(() => {
									if (hit.pickedMesh) hit.pickedMesh.renderOutline = false;
								}, 100);

								if (zObj.hp <= 0) {
									zObj.isDead = true;
									if (zObj.anims) zObj.anims.forEach(a => a.stop());

									zObj.collider.checkCollisions = false;
									zObj.collider.rotation.x = Math.PI / 2;
									zObj.collider.position.y -= 0.5;

									setTimeout(() => {
										zObj.collider.dispose();
										let idx = zombiesList.indexOf(zObj);
										if (idx > -1) zombiesList.splice(idx, 1);
									}, 3000);
								}
							}
						}
					}
				}

				scene.onPointerObservable.add((pointerInfo) => {
					if (pointerInfo.type === BABYLON.PointerEventTypes.POINTERDOWN) {
						if (!engine.isPointerLock) return;

						if (isBuildMode) {
							if (pointerInfo.event.button === 2 && !isWheelOpen) {
								isWheelOpen = true;
								radialDelta = {
									x: 0,
									y: 0
								};
								activeWheelIndex = -1;
								document.getElementById("radial-menu-overlay").style.display = "block";
								camera.angularSensibility = 1e9;
								Object.values(ghostMeshes).forEach(g => g.isVisible = false);
								clearOutline();
								updateRadialUI();
							} else if (pointerInfo.event.button === 0 && !isWheelOpen) {
								if (currentMode === TYPE.DESTROY) {
									if (lastOutlinedMesh) destroyBlock(lastOutlinedMesh);
								} else if (currentPlacementValid && currentPlacementData) buildBlock(
									currentPlacementData);
							}
						} else {
							if (pointerInfo.event.button === 0 && !isWheelOpen) {
								shootWeapon();
							}
						}
					} else if (pointerInfo.type === BABYLON.PointerEventTypes.POINTERUP) {
						if (pointerInfo.event.button === 2 && isWheelOpen) {
							isWheelOpen = false;
							document.getElementById("radial-menu-overlay").style.display = "none";
							camera.angularSensibility = 1000;
							document.getElementById('radial-cursor').style.transform =
								`translate(0px, 0px) translate(-50%, -50%)`;
							if (activeWheelIndex >= 0 && activeWheelIndex < wheelItems.length) {
								currentMode = wheelItems[activeWheelIndex].type;
								const modeText = document.getElementById("modeText");
								modeText.innerText = wheelItems[activeWheelIndex].name;
								modeText.style.color = currentMode === TYPE.DESTROY ? "#e74c3c" : "#2ecc71";
							}
						}
					} else if (pointerInfo.type === BABYLON.PointerEventTypes.POINTERMOVE) {
						if (!engine.isPointerLock) return;
						if (isWheelOpen) {
							radialDelta.x += pointerInfo.event.movementX;
							radialDelta.y += pointerInfo.event.movementY;
							const dist = Math.sqrt(radialDelta.x ** 2 + radialDelta.y ** 2);
							let cx = radialDelta.x,
								cy = radialDelta.y;
							if (dist > 280) {
								cx = (radialDelta.x / dist) * 280;
								cy = (radialDelta.y / dist) * 280;
							}
							document.getElementById('radial-cursor').style.transform =
								`translate(${cx}px, ${cy}px) translate(-50%, -50%)`;
							if (dist > 30) {
								let deg = (Math.atan2(radialDelta.y, radialDelta.x) * 180 / Math.PI + 90 + 360) %
								360;
								activeWheelIndex = Math.floor((deg + (360 / wheelItems.length) / 2) / (360 /
									wheelItems.length)) % wheelItems.length;
							} else activeWheelIndex = -1;
							updateRadialUI();
							return;
						}

						if (!isBuildMode) return;
						const pickResult = scene.pick(scene.pointerX, scene.pointerY);
						currentPlacementValid = false;
						Object.values(ghostMeshes).forEach(g => g.isVisible = false);

						if (currentMode === TYPE.DESTROY) {
							if (pickResult.hit && pickResult.pickedMesh && pickResult.pickedMesh.metadata &&
								pickResult.pickedMesh.metadata.type) {
								let hm = pickResult.pickedMesh;
								if (lastOutlinedMesh !== hm) {
									clearOutline();
									lastOutlinedMesh = hm;
									hm.renderOutline = true;
									hm.outlineColor = BABYLON.Color3.Red();
									hm.outlineWidth = 0.05;
								}
							} else clearOutline();
							return;
						} else clearOutline();

						if (pickResult.hit && pickResult.pickedPoint) {
							const pt = pickResult.pickedPoint;
							const mesh = pickResult.pickedMesh;
							let px = 0,
								py = 0,
								pz = 0,
								finalRotationY = 0,
								foundSnap = false;
							let bestSocket = null;
							let minDist = 2.5;
							for (let [id, block] of blocks) {
								let bType = block.metadata.type;
								if (!Sockets[bType]) continue;
								Sockets[bType].forEach(sock => {
									let dPos = sock.detectPos || sock.pos;
									let wPos = BABYLON.Vector3.TransformCoordinates(dPos, block
										.getWorldMatrix());
									let dist = BABYLON.Vector3.Distance(wPos, pt);
									if (dist < minDist) {
										let canSnap = false;
										if (isFoundationType(currentMode) && isFoundationType(bType))
											canSnap = true;
										else if (isFloorType(currentMode) && (isFloorType(bType) ||
												isWallType(bType) || isFoundationType(bType))) canSnap =
										true;
										else if (isWallType(currentMode) && (isFoundationType(bType) ||
												isFloorType(bType) || isWallType(bType))) canSnap = true;
										else if (isStairType(currentMode) && (isFoundationType(bType) ||
												isFloorType(bType))) canSnap = true;

										if (canSnap) {
											minDist = dist;
											let truePos = BABYLON.Vector3.TransformCoordinates(sock.pos,
												block.getWorldMatrix());
											bestSocket = {
												pos: truePos,
												norm: BABYLON.Vector3.TransformNormal(sock.norm, block
													.getWorldMatrix()).normalize(),
												block: block,
												type: bType
											};
										}
									}
								});
							}

							if (bestSocket) {
								if (isFoundationType(currentMode) || isFloorType(currentMode)) {
									if (isFoundationType(bestSocket.type) || isFloorType(bestSocket.type) ||
										isWallType(bestSocket.type)) {
										let ghostSockets = Sockets[currentMode];
										let activeGhostSocket = ghostSockets[manualRotationSteps % ghostSockets
											.length];
										let targetNorm = bestSocket.norm.scale(-1);
										let angle = Math.atan2(targetNorm.x, targetNorm.z) - Math.atan2(
											activeGhostSocket.norm.x, activeGhostSocket.norm.z);
										finalRotationY = angle;
										let rotatedPos = BABYLON.Vector3.TransformCoordinates(activeGhostSocket.pos,
											BABYLON.Matrix.RotationY(angle));
										px = bestSocket.pos.x - rotatedPos.x;
										pz = bestSocket.pos.z - rotatedPos.z;
										if (isWallType(bestSocket.type)) py = bestSocket.pos.y + BASE_THICKNESS / 2;
										else py = bestSocket.pos.y - rotatedPos.y;
										foundSnap = true;
									}
								} else if (isWallType(currentMode)) {
									if (isFoundationType(bestSocket.type) || isFloorType(bestSocket.type)) {
										finalRotationY = Math.atan2(bestSocket.norm.x, bestSocket.norm.z);
										px = bestSocket.pos.x;
										pz = bestSocket.pos.z;
										py = bestSocket.block.position.y + BASE_THICKNESS / 2 + (currentMode === TYPE
											.LOW_WALL ? WALL_HEIGHT / 4 : WALL_HEIGHT / 2);
										foundSnap = true;
									} else if (isWallType(bestSocket.type)) {
										px = bestSocket.block.position.x;
										pz = bestSocket.block.position.z;
										finalRotationY = bestSocket.block.rotation.y;
										py = bestSocket.block.position.y + (bestSocket.type === TYPE.LOW_WALL ?
											WALL_HEIGHT / 2 : WALL_HEIGHT) / 2 + (currentMode === TYPE.LOW_WALL ?
											WALL_HEIGHT / 4 : WALL_HEIGHT / 2);
										foundSnap = true;
									}
								} else if (isStairType(currentMode)) {
									px = bestSocket.block.position.x;
									pz = bestSocket.block.position.z;
									py = bestSocket.block.position.y + BASE_THICKNESS / 2;
									finalRotationY = manualRotationSteps * (Math.PI / 2);
									foundSnap = true;
								}
							}

							if (!foundSnap && mesh && mesh.name === "ground" && isFoundationType(currentMode)) {
								px = Math.round(pt.x / (GRID_SIZE / 2)) * (GRID_SIZE / 2);
								pz = Math.round(pt.z / (GRID_SIZE / 2)) * (GRID_SIZE / 2);
								py = BASE_THICKNESS / 2;
								finalRotationY = manualRotationSteps * (currentMode === TYPE.FOUNDATION_TRI ? Math
									.PI / 3 : Math.PI / 2);
								foundSnap = true;
							}

							if (foundSnap) {
								let tempPos = new BABYLON.Vector3(px, py, pz);
								for (let [id, block] of blocks) {
									let t = block.metadata.type;
									if ((isFoundationType(currentMode) || isFloorType(currentMode)) && (
											isFoundationType(t) || isFloorType(t))) {
										if (BABYLON.Vector3.Distance(block.position, tempPos) < 1.0) {
											foundSnap = false;
											break;
										}
									}
									if (isWallType(currentMode) && isWallType(t)) {
										if (BABYLON.Vector3.Distance(block.position, tempPos) < 0.5) {
											foundSnap = false;
											break;
										}
									}
								}
							}

							if (foundSnap) {
								let ghost = ghostMeshes[currentMode];
								ghost.position.set(px, py, pz);
								ghost.rotation.y = finalRotationY;
								ghost.isVisible = true;
								currentPlacementData = {
									x: px,
									y: py,
									z: pz,
									type: currentMode,
									ry: finalRotationY
								};
								currentPlacementValid = true;
							}
						}
					}
				});

				canvas.addEventListener("click", () => {
					if (!isWheelOpen) engine.enterPointerlock();
				});
				canvas.oncontextmenu = e => e.preventDefault();

				function buildBlock(data) {
					let mesh = templates[data.type].clone("block_" + data.type);
					mesh.position.set(data.x, data.y, data.z);
					mesh.rotation.y = data.ry;
					let id = getUniqueId();
					mesh.metadata = {
						id: id,
						type: data.type,
						hp: 3
					};
					mesh.isVisible = true;
					mesh.isPickable = true;
					mesh.getChildMeshes(false).forEach(c => c.metadata = mesh.metadata);
					mesh.checkCollisions = true;
					if (data.type === TYPE.DOORWAY) {
						let hinge = mesh.getChildren()[0];
						let panel = hinge.getChildren()[0];
						panel.isVisible = true;
						panel.checkCollisions = true;
						globalDoors.push({
							mesh: mesh,
							hinge: hinge,
							currentRot: 0
						});
					}
					blocks.set(id, mesh);
				}

				// ✅ 修正2：加入了防递归和非空安全判定
				function destroyBlock(mesh, skipIntegrityCheck = false) {
					if (!mesh || mesh.isDisposed() || !mesh.metadata || !mesh.metadata.type) return;
					if (lastOutlinedMesh === mesh) clearOutline();

					blocks.delete(mesh.metadata.id);
					mesh.isPickable = false;
					mesh.checkCollisions = false;
					for (let i = 0; i < 8 + Math.floor(Math.random() * 5); i++) {
						let frag = BABYLON.MeshBuilder.CreateBox("frag", {
							size: 0.2 + Math.random() * 0.4
						}, scene);
						frag.position.copyFrom(mesh.position);
						frag.position.addInPlace(new BABYLON.Vector3((Math.random() - 0.5) * 1.5, Math.random() * 1.5, (Math
							.random() - 0.5) * 1.5));
						frag.material = matWood;
						frag.physicsImpostor = new BABYLON.PhysicsImpostor(frag, BABYLON.PhysicsImpostor.BoxImpostor, {
							mass: 1,
							restitution: 0.1,
							friction: 0.8
						}, scene);
						frag.physicsImpostor.applyImpulse(new BABYLON.Vector3((Math.random() - 0.5) * 6, Math.random() * 5 +
							3, (Math.random() - 0.5) * 6), frag.getAbsolutePosition());
						setTimeout(() => {
							if (frag && !frag.isDisposed()) frag.dispose();
						}, 3000 + Math.random() * 1500);
					}
					mesh.dispose();
					if (mesh.metadata.type === TYPE.DOORWAY) {
						let idx = globalDoors.findIndex(d => d.mesh === mesh);
						if (idx > -1) globalDoors.splice(idx, 1);
					}

					if (!skipIntegrityCheck && !isCheckingIntegrity) {
						checkStructuralIntegrity();
					}
				}

				// ✅ 修正2补充：在做连接判定时也加入了防崩溃空校验
				function areBlocksConnected(m1, m2) {
					if (!m1 || !m2 || m1.isDisposed() || m2.isDisposed() || !m1.metadata || !m2.metadata) return false;
					let p1 = m1.position,
						p2 = m2.position,
						dy = Math.abs(p1.y - p2.y),
						dH = Math.sqrt(Math.pow(p1.x - p2.x, 2) + Math.pow(p1.z - p2.z, 2));
					if (dH < 1.0) return dy <= WALL_HEIGHT + 0.1;
					if (dy < 1.0) return dH <= GRID_SIZE + 0.2;
					if (dy <= WALL_HEIGHT / 2 + 0.2) return dH <= GRID_SIZE / 2 + 0.2;
					if (isStairType(m1.metadata.type) || isStairType(m2.metadata.type)) return dH <= GRID_SIZE + 0.2 && dy <=
						WALL_HEIGHT + 0.2;
					return false;
				}

				function checkStructuralIntegrity() {
					if (isCheckingIntegrity) return; // 防递归锁
					isCheckingIntegrity = true;

					const stableBlocks = new Set(),
						queue = [];
					blocks.forEach((mesh, id) => {
						if (isFoundationType(mesh.metadata.type)) {
							stableBlocks.add(id);
							queue.push(mesh);
						}
					});
					while (queue.length > 0) {
						const current = queue.shift();
						blocks.forEach((otherMesh, otherId) => {
							if (!stableBlocks.has(otherId) && areBlocksConnected(current, otherMesh)) {
								stableBlocks.add(otherId);
								queue.push(otherMesh);
							}
						});
					}
					const toCollapse = [];
					blocks.forEach((mesh, id) => {
						if (!stableBlocks.has(id)) toCollapse.push(mesh);
					});
					toCollapse.forEach(mesh => destroyBlock(mesh, true)); // true表示跳过嵌套校验

					isCheckingIntegrity = false;
				}

				scene.onBeforeRenderObservable.add(() => {
					globalDoors.forEach(doorObj => {
						let dist = BABYLON.Vector3.Distance(camera.position, doorObj.mesh
							.getAbsolutePosition());
						let targetRot = dist < 3.0 ? -Math.PI / 2 : 0;
						doorObj.currentRot = BABYLON.Scalar.Lerp(doorObj.currentRot, targetRot, 0.1);
						doorObj.hinge.rotation.y = doorObj.currentRot;
					});
				});

				let playerHP = 100;
				let prepTime = 60;
				let isPrepPhase = true;
				let prepInterval = setInterval(() => {
					prepTime--;
					if (prepTime > 0) {
						document.getElementById('prepTimer').innerText = `准备建家: ${prepTime}s`;
					} else {
						isPrepPhase = false;
						document.getElementById('prepTimer').innerText = `丧尸来袭！`;
						document.getElementById('prepTimer').style.color = '#e74c3c';
						clearInterval(prepInterval);
					}
				}, 1000);

				function takeDamage(amount) {
					if (playerHP <= 0) return;
					playerHP -= amount;
					if (playerHP < 0) playerHP = 0;
					document.getElementById('hpBar').style.width = playerHP + '%';
					let dmgOverlay = document.getElementById('damageOverlay');
					dmgOverlay.style.opacity = 1;
					setTimeout(() => dmgOverlay.style.opacity = 0, 150);
					if (playerHP <= 0) {
						document.getElementById('prepTimer').innerText = `你死了...`;
						engine.stopRenderLoop();
						alert("你被丧尸吃掉了！按F5刷新页面重新开始！");
					}
				}

				let zombiesList = [];
				let zombieContainer = null;

				BABYLON.SceneLoader.LoadAssetContainerAsync(ZOMBIE_MODEL_URL, ZOMBIE_MODEL_FILE, scene).then((container) => {
					zombieContainer = container;
					if (container.animationGroups && container.animationGroups.length > 0) {
						container.animationGroups.forEach(ag => ag.stop());
					}
				});

				setInterval(() => {
					if (isPrepPhase) return;
					if (!zombieContainer || zombiesList.length >= 20) return;

					let collider = BABYLON.MeshBuilder.CreateBox("zcol_" + Date.now(), {
						width: 0.6,
						height: 1.8,
						depth: 0.6
					}, scene);
					let angle = Math.random() * Math.PI * 2;
					let dist = 25 + Math.random() * 15;
					collider.position = new BABYLON.Vector3(camera.position.x + Math.cos(angle) * dist, 0.9, camera
						.position.z + Math.sin(angle) * dist);
					collider.checkCollisions = true;
					collider.ellipsoid = new BABYLON.Vector3(0.3, 0.9, 0.3);
					collider.isVisible = false;

					let entries = zombieContainer.instantiateModelsToScene();
					let rootNode = entries.rootNodes[0];

					rootNode.parent = collider;
					rootNode.position = new BABYLON.Vector3(0, -0.9, 0);

					rootNode.scaling = new BABYLON.Vector3(ZOMBIE_SCALE, ZOMBIE_SCALE, ZOMBIE_SCALE);

					rootNode.getChildMeshes().forEach(m => {
						m.isVisible = true;
						m.isPickable = true;
						m.metadata = {
							isZombie: true,
							root: rootNode
						};
					});

					let anims = entries.animationGroups;
					if (anims && anims.length > 0) anims[0].play(true);

					zombiesList.push({
						collider: collider,
						root: rootNode,
						hp: 100,
						anims: anims,
						isDead: false,
						lastAttack: 0
					});
				}, 3000);

				scene.onBeforeRenderObservable.add(() => {
					const zombieSpeed = 0.04;
					for (let i = zombiesList.length - 1; i >= 0; i--) {
						let zObj = zombiesList[i];
						if (zObj.isDead) continue;

						let dirToPlayer = camera.position.clone().subtract(zObj.collider.position);
						let distance3D = dirToPlayer.length();

						let moveDir = dirToPlayer.clone();
						moveDir.y = 0;
						moveDir.normalize();

						if (distance3D < 2.5) {
							if (Date.now() - zObj.lastAttack > 1000) {
								takeDamage(15);
								zObj.lastAttack = Date.now();
							}
						} else {
							let forwardRay = new BABYLON.Ray(zObj.collider.position, moveDir, 1.2);
							let hitStruct = scene.pickWithRay(forwardRay, (m) => m.metadata && m.metadata.type && m
								.metadata.type !== TYPE.DESTROY);

							if (hitStruct.hit && hitStruct.pickedMesh) {
								if (Date.now() - zObj.lastAttack > 1000) {
									let bMesh = hitStruct.pickedMesh;

									if (bMesh.metadata && bMesh.metadata.hp !== undefined) {
										bMesh.metadata.hp -= 1;

										bMesh.renderOutline = true;
										bMesh.outlineColor = BABYLON.Color3.Red();
										bMesh.outlineWidth = 0.05;
										setTimeout(() => {
											if (bMesh && !bMesh.isDisposed()) bMesh.renderOutline = false;
										}, 200);

										if (bMesh.metadata.hp <= 0) {
											let rootBlock = blocks.get(bMesh.metadata.id);
											// 加入强判定，确保调用的毁坏建筑目标未被意外释放
											if (rootBlock && !rootBlock.isDisposed()) {
												destroyBlock(rootBlock);
											}
										}
									}
									zObj.lastAttack = Date.now();
								}
							} else {
								let moveVec = moveDir.scale(zombieSpeed);
								moveVec.y = -0.2;
								zObj.collider.moveWithCollisions(moveVec);
							}
						}

						zObj.collider.lookAt(new BABYLON.Vector3(camera.position.x, zObj.collider.position.y, camera
							.position.z));
						// ✅ 修正3：取消了背身180度反转设定，模型会直面朝着你走来
						zObj.root.rotation = new BABYLON.Vector3(0, 0, 0);
					}
				});

				return scene;
			};

			const scene = createScene();
			engine.runRenderLoop(() => scene.render());
			window.addEventListener("resize", () => engine.resize());
		</script>
	</body>
</html>
